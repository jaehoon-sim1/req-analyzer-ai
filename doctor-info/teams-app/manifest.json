{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "{{TEAMS_BOT_APP_ID}}",
  "developer": {
    "name": "DoctorInfo Team",
    "websiteUrl": "https://doctor-info.vercel.app",
    "privacyUrl": "https://doctor-info.vercel.app/privacy",
    "termsOfUseUrl": "https://doctor-info.vercel.app/terms"
  },
  "name": {
    "short": "닥터인포",
    "full": "닥터인포 - AI 지식 비서"
  },
  "description": {
    "short": "팀의 내부 지식을 학습한 AI 비서",
    "full": "닥터인포는 팀의 문서와 대화 내용을 학습하여 질문에 답변하는 AI 비서입니다. 문서를 업로드하면 RAG 기반으로 정확한 답변을 제공합니다."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#2563EB",
  "bots": [
    {
      "botId": "{{TEAMS_BOT_APP_ID}}",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal"],
          "commands": [
            {
              "title": "도움말",
              "description": "닥터인포 사용법 안내"
            }
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["doctor-info.vercel.app"]
}
